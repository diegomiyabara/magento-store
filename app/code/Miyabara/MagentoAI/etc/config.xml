<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <miyabara_mageai>
            <general>
                <enabled>1</enabled>
                <baseline_prompt></baseline_prompt>
            </general>
            <api>
                <provider>openai</provider>
                <openai_base_url>https://api.openai.com</openai_base_url>
                <openai_model>gpt-4o</openai_model>
                <anthropic_base_url>https://api.anthropic.com</anthropic_base_url>
                <anthropic_model>claude-sonnet-4-6</anthropic_model>
                <gemini_base_url>https://generativelanguage.googleapis.com</gemini_base_url>
                <gemini_model>gemini-2.5-flash</gemini_model>
            </api>
            <description>
                <temperature>0.5</temperature>
                <full_max_tokens>1024</full_max_tokens>
                <short_max_tokens>256</short_max_tokens>
                <full_prompt>Write an SEO-optimized HTML product description for {{ product.name }}. Use the following product details: {{ product.attributes }}. Structure with clear paragraphs. Return only the HTML content.</full_prompt>
                <short_prompt>Write a concise 1-2 sentence product summary for {{ product.name }}. Use the following product details: {{ product.attributes }}. Return plain text only, no HTML.</short_prompt>
            </description>
            <image>
                <openai_model>gpt-image-1</openai_model>
                <openai_size>1024x1024</openai_size>
                <openai_quality>medium</openai_quality>
                <gemini_model>gemini-2.0-flash-exp-image-generation</gemini_model>
                <prompt>Professional product photo of {{ product.name }} on a clean white background, studio lighting, high resolution, e-commerce style.</prompt>
                <modify_prompt>Edit this product image as follows: {{ instructions }}. Maintain professional e-commerce quality, white background, studio lighting.</modify_prompt>
            </image>
        </miyabara_mageai>
    </default>
</config>
