<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Magento_Backend::system">
                    <resource id="Miyabara_MagentoAI::mageai"
                              title="Miyabara MagentoAI"
                              sortOrder="100">
                        <resource id="Miyabara_MagentoAI::generate"
                                  title="Generate text and images"
                                  sortOrder="10"/>
                    </resource>
                </resource>
                <resource id="Magento_Config::config">
                    <resource id="Miyabara_MagentoAI::config"
                              title="Miyabara MagentoAI Settings"
                              sortOrder="100"/>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
