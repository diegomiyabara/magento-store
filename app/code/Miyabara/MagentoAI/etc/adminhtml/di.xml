<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Plugin: inject MagentoAI generate buttons into the TinyMCE editor element -->
    <type name="Magento\Framework\Data\Form\Element\Editor">
        <plugin name="miyabara_mageai_editor_buttons"
                type="Miyabara\MagentoAI\Plugin\EditorButtonsPlugin"
                sortOrder="10"/>
    </type>

</config>
