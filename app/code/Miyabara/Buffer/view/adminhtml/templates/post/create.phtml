<script>
require(['jquery'], function ($) {
    'use strict';

    var syncUrl    = <?= /* @noEscape */ json_encode($syncUrl) ?>;
    var searchUrl  = <?= /* @noEscape */ json_encode($searchUrl) ?>;
    var formKey    = <?= /* @noEscape */ json_encode($formKey) ?>;

    /* ── Character counter ─────────────────────────────────── */
    $('#buffer-post-text').on('input', function () {
        var remaining = 2200 - this.value.length;
        $('#buffer-char-remaining').text(remaining);
        if (remaining < 50) {
            $('#buffer-char-remaining').css('color', '#ef4444');
        } else {
            $('#buffer-char-remaining').css('color', '#94a3b8');
        }
    });

    /* ── Image URL preview ─────────────────────────────────── */
    var imagePreviewTimer;
    $('#buffer-image-url').on('input', function () {
        clearTimeout(imagePreviewTimer);
        var url = this.value.trim();
        if (!url) {
            $('#buffer-image-preview-wrap').hide();
            return;
        }
        imagePreviewTimer = setTimeout(function () {
            $('#buffer-image-preview').attr('src', url);
            $('#buffer-image-preview-wrap').show();
        }, 500);
    });

    /* ── Scheduling mode toggle ────────────────────────────── */
    $('input[name="scheduling_mode"]').on('change', function () {
        if (this.value === 'customScheduled') {
            $('#buffer-datetime-wrap').show();
        } else {
            $('#buffer-datetime-wrap').hide();
        }
    });

    /* ── Product search autocomplete ───────────────────────── */
    var searchTimer;
    $('#buffer-product-search').on('input', function () {
        clearTimeout(searchTimer);
        var q = this.value.trim();
        if (q.length < 2) {
            $('#buffer-product-results').hide();
            return;
        }
        searchTimer = setTimeout(function () {
            $.ajax({
                url: searchUrl,
                data: { q: q, form_key: formKey },
                success: function (products) {
                    var $ul = $('#buffer-product-results').empty();
                    if (!products.length) {
                        $ul.append('<li style="padding:10px 12px;color:#94a3b8;font-size:0.85rem;"><?= $escaper->escapeJs(__('No products found.')) ?></li>');
                    } else {
                        $.each(products, function (i, p) {
                            var $li = $('<li>');
                            $li.append('<img src="' + $('<div>').text(p.imageUrl).html() + '" alt="">');
                            $li.append('<div><div class="ac-name">' + $('<div>').text(p.name).html() + '</div><div class="ac-sku">SKU: ' + $('<div>').text(p.sku).html() + '</div></div>');
                            $li.on('click', function () {
                                selectProduct(p);
                            });
                            $ul.append($li);
                        });
                    }
                    $ul.show();
                }
            });
        }, 300);
    });

    $(document).on('click', function (e) {
        if (!$(e.target).closest('.buffer-search-wrap').length) {
            $('#buffer-product-results').hide();
        }
    });

    function selectProduct(p) {
        $('#buffer-product-results').hide();
        $('#buffer-product-search').val('');

        $('#buffer-product-thumb').attr('src', p.imageUrl);
        $('#buffer-product-name').text(p.name);
        $('#buffer-product-sku').text('SKU: ' + p.sku);
        $('#buffer-product-preview').show();

        /* Pre-fill text */
        var text = p.name;
        if (p.description) {
            text += '\n\n' + p.description;
        }
        $('#buffer-post-text').val(text).trigger('input');

        /* Pre-fill image */
        $('#buffer-image-url').val(p.imageUrl).trigger('input');
    }

    $('#buffer-product-clear').on('click', function () {
        $('#buffer-product-preview').hide();
    });

    /* ── Channel sync ──────────────────────────────────────── */
    function renderChannels(channels) {
        var $wrap = $('#buffer-channels-wrap').empty();
        if (!channels.length) {
            $wrap.append('<p class="buffer-hint-text"><?= $escaper->escapeJs(__('No channels found in your Buffer account.')) ?></p>');
            return;
        }
        $.each(channels, function (i, ch) {
            var name        = ch.displayName || ch.name || 'Channel';
            var service     = ch.service || '';
            var avatarHtml  = ch.avatar
                ? '<img class="ch-avatar" src="' + $('<div>').text(ch.avatar).html() + '" alt="">'
                : '<div class="ch-avatar-placeholder">' + $('<div>').text(name.charAt(0).toUpperCase()).html() + '</div>';

            var $item = $('<label class="buffer-channel-item">');
            $item.append('<input type="checkbox" name="channel_ids[]" value="' + $('<div>').text(ch.id).html() + '">');
            $item.append(avatarHtml);
            $item.append('<div class="ch-info"><div class="ch-name">' + $('<div>').text(name).html() + '</div><div class="ch-service">' + $('<div>').text(service).html() + '</div></div>');
            $wrap.append($item);
        });
    }

    $('#buffer-sync-btn').on('click', function () {
        var $btn = $(this);
        $btn.html('<span class="buffer-spinner"></span><?= $escaper->escapeJs(__('Syncing…')) ?>').prop('disabled', true);

        $.ajax({
            url: syncUrl,
            method: 'POST',
            data: { form_key: formKey },
            success: function (resp) {
                if (resp.success) {
                    renderChannels(resp.channels);
                    $('#buffer-channels-hint').remove();
                } else {
                    alert('<?= $escaper->escapeJs(__('Sync failed: ')) ?>' + resp.error);
                }
            },
            error: function () {
                alert('<?= $escaper->escapeJs(__('Network error while syncing channels.')) ?>');
            },
            complete: function () {
                $btn.html('↻ <?= $escaper->escapeJs(__('Sync')) ?>').prop('disabled', false);
            }
        });
    });

    /* ── Form submit: copy values to hidden inputs ─────────── */
    $('#buffer-post-form').on('submit', function (e) {
        var text = $('#buffer-post-text').val().trim();
        if (!text) {
            e.preventDefault();
            alert('<?= $escaper->escapeJs(__('Post text cannot be empty.')) ?>');
            return;
        }

        var checked = $('input[name="channel_ids[]"]:checked');
        if (!checked.length) {
            e.preventDefault();
            alert('<?= $escaper->escapeJs(__('Please select at least one channel.')) ?>');
            return;
        }

        $('#buffer-post-text-hidden').val(text);
        $('#buffer-image-url-hidden').val($('#buffer-image-url').val().trim());
        $('#buffer-scheduling-mode-hidden').val($('input[name="scheduling_mode"]:checked').val());
        $('#buffer-due-at-hidden').val($('#buffer-due-at').val());

        /* Copy channel checkboxes into the hidden container */
        var $container = $('#buffer-channel-ids-container').empty();
        checked.each(function () {
            $container.append(
                $('<input type="hidden" name="channel_ids[]">').val($(this).val())
            );
        });
    });
});
</script>
