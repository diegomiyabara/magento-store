<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="checkout.success">
            <action method="setTemplate">
                <argument name="template" xsi:type="string">Dm3d_CheckoutCustom::success.phtml</argument>
            </action>
        </referenceBlock>
        <referenceBlock name="logo" remove="true"/>
        <referenceContainer name="checkout.header.wrapper">
            <block class="Magento\Framework\View\Element\Template"
                   name="dm3d.checkout.header.success"
                   template="Dm3d_CheckoutCustom::header.phtml"
                   before="-"/>
        </referenceContainer>
    </body>
</page>
